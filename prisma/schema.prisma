generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────────
// ORGANISATIONS
// ─────────────────────────────────────────────

model Organisation {
  id             String   @id @default(cuid())
  name           String
  slug           String   @unique
  monthlyLimit   Int      @default(100)
  creditBalance  Int      @default(0)
  active         Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  // Subscription
  subscriptionTier       String?   // FREE, PRO, AGENCY
  stripeSubscriptionId   String?   @unique
  subscriptionStatus     String?   // active, canceled, past_due, trialing
  monthlyCreditsIncluded Int       @default(0)
  monthlyCreditsUsed     Int       @default(0)
  currentPeriodStart     DateTime?
  currentPeriodEnd       DateTime?

  users              User[]
  invites            Invite[]
  bulkCheckJobs      BulkCheckJob[]
  creditTransactions CreditTransaction[]
  integrations       Integration[]

  @@map("organisations")
}

// ─────────────────────────────────────────────
// USERS & AUTH
// ─────────────────────────────────────────────

model User {
  id                 String    @id @default(cuid())
  username           String    @unique
  email              String    @unique
  name               String
  passwordHash       String
  role               UserRole  @default(USER)
  active             Boolean   @default(true)
  forcePasswordReset Boolean   @default(false)
  lastLoginAt        DateTime?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  organisationId   String?
  organisation     Organisation? @relation(fields: [organisationId], references: [id])
  stripeCustomerId String?       @unique

  complianceChecks    ComplianceCheck[]
  confirmedChanges    ProposedChange[]       @relation("ConfirmedBy")
  complianceExamples  ComplianceExample[]
  categoryOverrides   CategoryOverrideAudit[]
  invitesSent         Invite[]               @relation("InvitedBy")
  bulkCheckJobs       BulkCheckJob[]
  reviewedCategories  Category[]             @relation("CategoryReviewer")
  creditTransactions  CreditTransaction[]
  integrations        Integration[]          @relation("ConnectedBy")
  verifiedLegislation Legislation[]          @relation("LegislationVerifier")
  verifiedPolicies    PlatformPolicy[]       @relation("PolicyVerifier")
  verifiedRules       ComplianceRule[]       @relation("RuleVerifier")

  @@index([organisationId])
  @@map("users")
}

enum UserRole {
  ADMIN
  USER
}

// ─────────────────────────────────────────────
// INVITES
// ─────────────────────────────────────────────

model Invite {
  id             String    @id @default(cuid())
  email          String
  token          String    @unique
  organisationId String?
  invitedById    String
  usedAt         DateTime?
  expiresAt      DateTime
  createdAt      DateTime  @default(now())

  organisation Organisation? @relation(fields: [organisationId], references: [id])
  invitedBy    User           @relation("InvitedBy", fields: [invitedById], references: [id])

  @@map("invites")
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  email     String
  token     String   @unique
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@map("password_reset_tokens")
}

// ─────────────────────────────────────────────
// ADVERTISING PLATFORMS
// ─────────────────────────────────────────────

model Platform {
  id          String   @id @default(cuid())
  name        String   @unique
  slug        String   @unique
  logoUrl     String
  parentName  String?
  active      Boolean  @default(true)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  channelRequirements    ChannelRequirement[]
  platformRules          PlatformRule[]
  geoRules               GeoRule[]
  scanSources            ScanSource[]
  complianceExamples     ComplianceExample[]
  platformCertifications PlatformCertification[]
  proposedChanges        ProposedChange[]
  prohibitionConfigs     ProhibitionConfig[] @relation("ProhibitionPlatform")
  policyArticles         PolicyArticle[]
  policyQuizzes          PolicyQuiz[]
  platformPolicies       PlatformPolicy[]
  complianceRules        ComplianceRule[]

  @@map("platforms")
}

model ChannelRequirement {
  id         String          @id @default(cuid())
  platformId String
  specType   ChannelSpecType
  specKey    String
  value      String
  notes      String?
  createdAt  DateTime        @default(now())
  updatedAt  DateTime        @updatedAt

  platform Platform @relation(fields: [platformId], references: [id])

  @@unique([platformId, specKey])
  @@map("channel_requirements")
}

enum ChannelSpecType {
  CHARACTER_LIMIT
  FILE_SIZE
  FILE_FORMAT
  DIMENSIONS
  DURATION
  SAFE_ZONE
  OTHER
}

// ─────────────────────────────────────────────
// PRODUCT / SERVICE CATEGORIES
// ─────────────────────────────────────────────

enum CategoryMaturity {
  ALPHA
  BETA
  LIVE
}

model Category {
  id               String           @id @default(cuid())
  name             String           @unique
  slug             String           @unique
  description      String?
  parentId         String?
  active           Boolean          @default(true)
  sortOrder        Int              @default(0)
  iconName         String?
  maturity         CategoryMaturity @default(ALPHA)
  lastReviewedAt   DateTime?
  lastReviewedById String?
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  parent     Category?  @relation("CategoryHierarchy", fields: [parentId], references: [id])
  children   Category[] @relation("CategoryHierarchy")
  reviewedBy User?      @relation("CategoryReviewer", fields: [lastReviewedById], references: [id])

  platformRules      PlatformRule[]
  geoRules           GeoRule[]
  proposedChanges    ProposedChange[]
  scanSources        ScanSource[]
  complianceExamples ComplianceExample[]
  prohibitionConfigs ProhibitionConfig[]
  policyArticles     PolicyArticle[]
  policyQuizzes      PolicyQuiz[]
  complianceRules    ComplianceRule[]

  @@map("categories")
}

// ─────────────────────────────────────────────
// COUNTRIES & GEOGRAPHIC RULES
// ─────────────────────────────────────────────

model Country {
  id           String           @id @default(cuid())
  name         String           @unique
  code         String           @unique
  region       GeographicRegion
  approved     Boolean          @default(false)
  approvedAt   DateTime?
  approvedById String?
  complexRules Boolean          @default(false)
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt

  geoRules           GeoRule[]
  proposedChanges    ProposedChange[]
  scanSources        ScanSource[]
  complianceExamples ComplianceExample[]
  prohibitionConfigs ProhibitionConfig[] @relation("ProhibitionCountry")
  policyArticles     PolicyArticle[]
  legislation        Legislation[]
  complianceRules    ComplianceRule[]

  @@map("countries")
}

enum GeographicRegion {
  NORTH_AMERICA
  LATIN_AMERICA
  EUROPEAN_UNION
  EUROPE_OTHER
  UNITED_KINGDOM
  MIDDLE_EAST_AFRICA
  ASIA_PACIFIC
  OCEANIA
  SOUTH_ASIA
}

// ─────────────────────────────────────────────
// COMPLIANCE RULES
// ─────────────────────────────────────────────

model PlatformRule {
  id             String     @id @default(cuid())
  platformId     String
  categoryId     String
  status         RuleStatus @default(UNKNOWN)
  notes          String?
  conditions     Json?
  referenceUrl   String?
  lastVerifiedAt DateTime?
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt

  platform Platform  @relation(fields: [platformId], references: [id])
  category Category  @relation(fields: [categoryId], references: [id])

  @@unique([platformId, categoryId])
  @@map("platform_rules")
}

model GeoRule {
  id             String     @id @default(cuid())
  countryId      String
  categoryId     String
  platformId     String?
  status         RuleStatus @default(UNKNOWN)
  restrictions   Json?
  notes          String?
  legislationUrl String?
  lastVerifiedAt DateTime?
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt

  country  Country   @relation(fields: [countryId], references: [id])
  category Category  @relation(fields: [categoryId], references: [id])
  platform Platform? @relation(fields: [platformId], references: [id])

  @@unique([countryId, categoryId, platformId])
  @@map("geo_rules")
}

enum RuleStatus {
  ALLOWED
  RESTRICTED
  PROHIBITED
  UNKNOWN
}

// ─────────────────────────────────────────────
// PROPOSED CHANGES (AUTO-SCAN WORKFLOW)
// ─────────────────────────────────────────────

model ProposedChange {
  id              String               @id @default(cuid())
  changeType      ProposedChangeType
  ruleType        RuleType
  platformId      String?
  categoryId      String?
  countryId       String?
  currentRuleId   String?
  currentRuleData Json?
  proposedData    Json
  aiSummary       String
  sourceUrl       String
  detectedAt      DateTime             @default(now())
  status          ProposedChangeStatus @default(PENDING)
  reviewedAt      DateTime?
  reviewedById    String?
  reviewNotes     String?

  platform   Platform? @relation(fields: [platformId], references: [id])
  category   Category? @relation(fields: [categoryId], references: [id])
  country    Country?  @relation(fields: [countryId], references: [id])
  reviewedBy User?     @relation("ConfirmedBy", fields: [reviewedById], references: [id])

  @@index([status, detectedAt])
  @@map("proposed_changes")
}

enum ProposedChangeType {
  NEW_RULE
  AMENDED_RULE
  REMOVED_RULE
}

enum RuleType {
  PLATFORM_RULE
  GEO_RULE
  CHANNEL_REQUIREMENT
}

enum ProposedChangeStatus {
  PENDING
  CONFIRMED
  REJECTED
}

// ─────────────────────────────────────────────
// SCAN SOURCES
// ─────────────────────────────────────────────

model ScanSource {
  id            String   @id @default(cuid())
  url           String   @unique
  label         String
  platformId    String?
  countryId     String?
  categoryId    String?
  lastScannedAt DateTime?
  lastHash      String?
  lastContent   String?
  active        Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  platform Platform?  @relation(fields: [platformId], references: [id])
  country  Country?   @relation(fields: [countryId], references: [id])
  category Category?  @relation(fields: [categoryId], references: [id])

  @@map("scan_sources")
}

// ─────────────────────────────────────────────
// SCAN LOGS
// ─────────────────────────────────────────────

model ScanLog {
  id             String      @id @default(cuid())
  startedAt      DateTime    @default(now())
  completedAt    DateTime?
  triggeredBy    ScanTrigger @default(CRON)
  sourcesScanned Int         @default(0)
  sourcesChanged Int         @default(0)
  changesCreated Int         @default(0)
  errorCount     Int         @default(0)
  errors         Json?

  @@map("scan_logs")
}

enum ScanTrigger {
  CRON
  MANUAL
}

// ─────────────────────────────────────────────
// COMPLIANCE CHECKS
// ─────────────────────────────────────────────

model ComplianceCheck {
  id            String           @id @default(cuid())
  userId        String
  status        ComplianceStatus @default(PENDING)
  platformIds   String[]
  categoryIds   String[]
  countryIds    String[]
  adContent     Json
  assetUrls     String[]
  results       Json?
  overallStatus ComplianceStatus?
  source        String?
  createdAt     DateTime         @default(now())
  completedAt   DateTime?

  bulkRowId String?
  bulkRow   BulkCheckRow? @relation(fields: [bulkRowId], references: [id])

  user      User       @relation(fields: [userId], references: [id])
  syncedAd  SyncedAd?

  @@index([userId, createdAt])
  @@map("compliance_checks")
}

// ─────────────────────────────────────────────
// BULK CHECK JOBS
// ─────────────────────────────────────────────

model BulkCheckJob {
  id              String         @id @default(cuid())
  userId          String
  organisationId  String?
  filename        String
  rowCount        Int
  uniqueRowCount  Int
  duplicateCount  Int            @default(0)
  mode            BulkCheckMode  @default(INSTANT)
  status          BulkJobStatus  @default(PENDING)
  checkditsCost   Decimal        @db.Decimal(10, 2)
  checkditsRefund Decimal        @default(0) @db.Decimal(10, 2)
  platformIds     String[]
  categoryIds     String[]
  countryIds      String[]
  columnMapping   Json
  resultsSummary  Json?
  submittedAt     DateTime       @default(now())
  startedAt       DateTime?
  completedAt     DateTime?
  notifiedAt      DateTime?

  user         User           @relation(fields: [userId], references: [id])
  organisation Organisation?  @relation(fields: [organisationId], references: [id])
  rows         BulkCheckRow[]

  @@index([userId])
  @@index([status])
  @@map("bulk_check_jobs")
}

model BulkCheckRow {
  id            String              @id @default(cuid())
  bulkJobId     String
  rowIndex      Int
  contentHash   String
  adContent     Json
  rawCsvRow     Json
  status        BulkRowStatus       @default(PENDING)
  isDuplicate   Boolean             @default(false)
  duplicateOfId String?
  overallStatus ComplianceStatus?
  results       Json?
  aiFixApplied       Boolean             @default(false)
  editedContent      Json?
  detectedCategoryId String?
  detectedCategoryName String?
  overrideCategoryIds Json?
  createdAt          DateTime            @default(now())
  completedAt        DateTime?

  bulkJob          BulkCheckJob          @relation(fields: [bulkJobId], references: [id], onDelete: Cascade)
  duplicateOf      BulkCheckRow?         @relation("RowDuplicates", fields: [duplicateOfId], references: [id])
  duplicates       BulkCheckRow[]        @relation("RowDuplicates")
  checks           ComplianceCheck[]
  categoryOverrides CategoryOverrideAudit[]

  @@unique([bulkJobId, rowIndex])
  @@index([bulkJobId, contentHash])
  @@map("bulk_check_rows")
}

enum BulkCheckMode {
  INSTANT
  BATCH
}

enum BulkJobStatus {
  PENDING
  PROCESSING
  COMPLETE
  FAILED
}

enum BulkRowStatus {
  PENDING
  PROCESSING
  COMPLETE
  FAILED
  SKIPPED_DUPLICATE
}

enum ComplianceStatus {
  PENDING
  RUNNING
  CLEAN
  WARNINGS
  VIOLATIONS
  ERROR
}

// ─────────────────────────────────────────────
// PLATFORM CERTIFICATIONS
// ─────────────────────────────────────────────

model PlatformCertification {
  id           String   @id @default(cuid())
  slug         String   @unique
  name         String
  platformId   String
  description  String
  infoUrl      String?
  categoryIds  String[]
  active       Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  platform Platform @relation(fields: [platformId], references: [id])
  orgCertifications OrgCertification[]

  @@map("platform_certifications")
}

model OrgCertification {
  id              String   @id @default(cuid())
  organisationId  String?
  userId          String
  certificationId String
  declaredAt      DateTime @default(now())
  declaredById    String
  evidenceUrl     String?
  notes           String?
  active          Boolean  @default(true)

  certification PlatformCertification @relation(fields: [certificationId], references: [id])

  @@unique([organisationId, certificationId])
  @@unique([userId, certificationId])
  @@map("org_certifications")
}

// ─────────────────────────────────────────────
// PROHIBITION CONFIGS (ADMIN-MANAGED)
// ─────────────────────────────────────────────

model ProhibitionConfig {
  id                  String   @id @default(cuid())
  categoryId          String
  countryId           String?
  platformId          String?

  // User-facing text
  warningTitle        String   @default("Regulatory restriction detected")
  warningMessage      String   @default("Your selected categories include jurisdictions where certain types of advertising are prohibited by law.")
  confirmationMessage String   @default("I confirm my adverts do not contravene this regulation")

  // AI detection guidance
  detectionGuidance   String?  @db.Text
  detectionExamples   Json?
  strictness          Int      @default(50)

  // Chat history for admin AI conversations about this config
  chatHistory         Json?

  active              Boolean  @default(true)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  category Category  @relation(fields: [categoryId], references: [id])
  country  Country?  @relation("ProhibitionCountry", fields: [countryId], references: [id])
  platform Platform? @relation("ProhibitionPlatform", fields: [platformId], references: [id])

  @@unique([categoryId, countryId, platformId])
  @@map("prohibition_configs")
}

// ─────────────────────────────────────────────
// AI TRAINING EXAMPLES
// ─────────────────────────────────────────────

enum ExampleVerdict {
  COMPLIANT
  NON_COMPLIANT
}

model ComplianceExample {
  id            String         @id @default(cuid())
  title         String
  contentSample String
  imageUrl      String?
  verdict       ExampleVerdict
  explanation   String
  rubric        Json?
  categoryId    String?
  platformId    String?
  countryId     String?
  active        Boolean        @default(true)
  version       Int            @default(1)
  supersededAt  DateTime?
  createdById   String
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  category  Category? @relation(fields: [categoryId], references: [id])
  platform  Platform? @relation(fields: [platformId], references: [id])
  country   Country?  @relation(fields: [countryId], references: [id])
  createdBy User      @relation(fields: [createdById], references: [id])

  @@map("compliance_examples")
}

// ─────────────────────────────────────────────
// CATEGORY OVERRIDE AUDIT LOG
// ─────────────────────────────────────────────

model CategoryOverrideAudit {
  id               String   @id @default(cuid())
  userId           String
  bulkRowId        String?
  bulkJobId        String?
  originalCategoryId   String
  originalCategoryName String
  overrideCategoryId   String
  overrideCategoryName String
  restrictionLevel     String   // "prohibited" | "restricted" | "allowed"
  acknowledgement      String   // the warning text the user acknowledged
  createdAt        DateTime @default(now())

  user    User          @relation(fields: [userId], references: [id])
  bulkRow BulkCheckRow? @relation(fields: [bulkRowId], references: [id])

  @@index([userId, createdAt])
  @@index([bulkRowId])
  @@map("category_override_audits")
}

// ─────────────────────────────────────────────
// BILLING
// ─────────────────────────────────────────────

model CreditTransaction {
  id                String    @id @default(cuid())
  userId            String
  organisationId    String?
  type              CreditTransactionType
  credits           Int
  stripeSessionId   String?   @unique
  stripePaymentId   String?
  packName          String?
  amountPaid        Int?      // in pence/cents
  currency          String?   @default("gbp")
  createdAt         DateTime  @default(now())

  user         User          @relation(fields: [userId], references: [id])
  organisation Organisation? @relation(fields: [organisationId], references: [id])

  @@index([userId, createdAt])
  @@index([organisationId])
  @@map("credit_transactions")
}

enum CreditTransactionType {
  PURCHASE      // bought via Stripe one-off pack
  SUBSCRIPTION  // monthly subscription credit allocation
  GRANT         // admin-granted free credits
  DEDUCTION     // spent on checks
  REFUND        // refunded for failed checks
  WELCOME       // signup welcome credits
}

// ─────────────────────────────────────────────
// INTEGRATIONS (OAuth connections to ad platforms)
// ─────────────────────────────────────────────

model Integration {
  id               String            @id @default(cuid())
  organisationId   String
  connectedById    String
  provider         IntegrationProvider
  status           IntegrationStatus @default(DISCONNECTED)
  label            String?           // user-given name, e.g. "Acme Meta Account"

  // OAuth tokens (encrypted at rest via application layer)
  accessToken      String?
  refreshToken     String?
  tokenExpiresAt   DateTime?
  scopes           String[]          // granted OAuth scopes

  // Provider-specific account info
  externalAccountId   String?        // e.g. Meta ad account ID, Google customer ID
  externalAccountName String?        // e.g. "Acme Corp Ad Account"
  accountMetadata     Json?          // extra provider-specific data

  // Sync settings
  autoSyncEnabled  Boolean           @default(false)
  syncIntervalMins Int               @default(60)   // how often to poll for new ads
  lastSyncAt       DateTime?
  lastSyncStatus   String?           // "success", "error: token expired", etc.
  lastSyncAdCount  Int?

  // Error tracking
  errorCount       Int               @default(0)
  lastErrorAt      DateTime?
  lastErrorMessage String?

  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  disconnectedAt   DateTime?

  organisation Organisation @relation(fields: [organisationId], references: [id])
  connectedBy  User         @relation("ConnectedBy", fields: [connectedById], references: [id])
  syncedAds    SyncedAd[]

  @@unique([organisationId, provider, externalAccountId])
  @@index([organisationId])
  @@index([provider, status])
  @@map("integrations")
}

model SyncedAd {
  id              String   @id @default(cuid())
  integrationId   String
  externalAdId    String   // ad ID in the external platform
  externalStatus  String?  // PAUSED, ACTIVE, etc.
  adContent       Json     // normalised ad content (headline, body, CTA, etc.)
  assetUrls       String[]
  rawPayload      Json?    // original API response for debugging
  complianceCheckId String? @unique
  lastSyncedAt    DateTime @default(now())
  createdAt       DateTime @default(now())

  integration     Integration      @relation(fields: [integrationId], references: [id], onDelete: Cascade)
  complianceCheck ComplianceCheck? @relation(fields: [complianceCheckId], references: [id])

  @@unique([integrationId, externalAdId])
  @@index([integrationId])
  @@map("synced_ads")
}

enum IntegrationProvider {
  META
  GOOGLE_ADS
  HUBSPOT
  HOOTSUITE
}

enum IntegrationStatus {
  CONNECTED
  DISCONNECTED
  ERROR       // token expired or revoked
  REFRESHING  // token refresh in progress
}

// ─────────────────────────────────────────────
// POLICY LIBRARY (LEARNING CONTENT)
// ─────────────────────────────────────────────

model PolicyArticle {
  id            String   @id @default(cuid())
  slug          String   @unique
  title         String
  summary       String   // Short description shown in listings
  content       String   @db.Text // Markdown body with explanations
  examples      Json?    // Array of { good: string, bad: string, explanation: string }
  videoUrl      String?  // YouTube embed URL
  videoTitle    String?  // Video title for display
  imageUrl      String?
  platformId    String?
  categoryId    String?
  countryId     String?
  tags          String[] // e.g. ["alcohol", "gambling", "age-gate", "disclaimer"]
  sortOrder     Int      @default(0)
  published     Boolean  @default(true)
  featured      Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  createdById   String?

  platform Platform? @relation(fields: [platformId], references: [id])
  category Category? @relation(fields: [categoryId], references: [id])
  country  Country?  @relation(fields: [countryId], references: [id])

  quizzes       PolicyQuiz[]
  resourceLinks ResourceLink[]

  @@index([platformId])
  @@index([categoryId])
  @@map("policy_articles")
}

// ─────────────────────────────────────────────
// POLICY QUIZZES (INTERACTIVE TESTS)
// ─────────────────────────────────────────────

model PolicyQuiz {
  id           String   @id @default(cuid())
  articleId    String?
  question     String   // e.g. "Identify the non-compliant terms in this ad"
  adCopy       String   @db.Text // The ad text the user must analyse
  problemTerms Json     // Array of { term: string, explanation: string }
  difficulty   QuizDifficulty @default(MEDIUM)
  platformId   String?
  categoryId   String?
  tags         String[]
  published    Boolean  @default(true)
  sortOrder    Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  article       PolicyArticle? @relation(fields: [articleId], references: [id])
  platform      Platform?      @relation(fields: [platformId], references: [id])
  category      Category?      @relation(fields: [categoryId], references: [id])
  resourceLinks ResourceLink[]

  @@index([articleId])
  @@map("policy_quizzes")
}

enum QuizDifficulty {
  EASY
  MEDIUM
  HARD
}

// ─────────────────────────────────────────────
// LEGISLATION REGISTRY
// ─────────────────────────────────────────────

enum LegislationType {
  STATUTE
  REGULATION
  DIRECTIVE
  INDUSTRY_CODE
  GUIDANCE
}

model Legislation {
  id               String           @id @default(cuid())
  title            String
  slug             String           @unique
  type             LegislationType
  jurisdictionId   String?
  region           GeographicRegion?
  sourceUrl        String?
  summary          String?          @db.Text
  fullText         String?          @db.Text
  effectiveDate    DateTime?
  expiryDate       DateTime?
  maturity         CategoryMaturity @default(ALPHA)
  lastVerifiedAt   DateTime?
  lastVerifiedById String?
  chatHistory      Json?
  tags             String[]
  active           Boolean          @default(true)
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  jurisdiction     Country?          @relation(fields: [jurisdictionId], references: [id])
  verifiedBy       User?             @relation("LegislationVerifier", fields: [lastVerifiedById], references: [id])
  complianceRules  ComplianceRule[]
  platformPolicies PlatformPolicyLegislation[]
  resourceLinks    ResourceLink[]

  @@index([jurisdictionId])
  @@index([type])
  @@map("legislation")
}

// ─────────────────────────────────────────────
// PLATFORM POLICIES
// ─────────────────────────────────────────────

model PlatformPolicy {
  id               String           @id @default(cuid())
  title            String
  slug             String           @unique
  platformId       String
  sourceUrl        String?
  summary          String?          @db.Text
  fullText         String?          @db.Text
  effectiveDate    DateTime?
  maturity         CategoryMaturity @default(ALPHA)
  lastVerifiedAt   DateTime?
  lastVerifiedById String?
  chatHistory      Json?
  active           Boolean          @default(true)
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  platform         Platform                   @relation(fields: [platformId], references: [id])
  verifiedBy       User?                      @relation("PolicyVerifier", fields: [lastVerifiedById], references: [id])
  complianceRules  ComplianceRule[]
  legislation      PlatformPolicyLegislation[]
  resourceLinks    ResourceLink[]

  @@index([platformId])
  @@map("platform_policies")
}

// Join table: which legislation backs which platform policies
model PlatformPolicyLegislation {
  id               String @id @default(cuid())
  platformPolicyId String
  legislationId    String

  platformPolicy PlatformPolicy @relation(fields: [platformPolicyId], references: [id], onDelete: Cascade)
  legislation    Legislation    @relation(fields: [legislationId], references: [id], onDelete: Cascade)

  @@unique([platformPolicyId, legislationId])
  @@map("platform_policy_legislation")
}

// ─────────────────────────────────────────────
// COMPLIANCE RULES (unified rule entity)
// ─────────────────────────────────────────────

enum ComplianceRuleSource {
  LEGISLATION
  PLATFORM_POLICY
  PLATFORM_INDEPENDENT
}

model ComplianceRule {
  id                 String               @id @default(cuid())
  categoryId         String
  platformId         String?
  countryId          String?

  sourceType         ComplianceRuleSource
  legislationId      String?
  platformPolicyId   String?

  status             RuleStatus           @default(UNKNOWN)
  title              String
  description        String?              @db.Text
  conditions         Json?
  aiCheckInstructions String?             @db.Text

  maturity           CategoryMaturity     @default(ALPHA)
  lastVerifiedAt     DateTime?
  lastVerifiedById   String?
  sortOrder          Int                  @default(0)
  active             Boolean              @default(true)
  createdAt          DateTime             @default(now())
  updatedAt          DateTime             @updatedAt

  // Hierarchy — general rules (no platform) can be parents of platform-specific rules
  parentRuleId     String?

  // Sync tracking — which runtime rule was created from this
  syncedPlatformRuleId String?
  syncedGeoRuleId      String?

  category         Category        @relation(fields: [categoryId], references: [id])
  platform         Platform?       @relation(fields: [platformId], references: [id])
  country          Country?        @relation(fields: [countryId], references: [id])
  legislation      Legislation?    @relation(fields: [legislationId], references: [id])
  platformPolicy   PlatformPolicy? @relation(fields: [platformPolicyId], references: [id])
  verifiedBy       User?           @relation("RuleVerifier", fields: [lastVerifiedById], references: [id])
  parentRule       ComplianceRule?  @relation("RuleHierarchy", fields: [parentRuleId], references: [id])
  childRules       ComplianceRule[] @relation("RuleHierarchy")
  resourceLinks    ResourceLink[]

  @@index([categoryId])
  @@index([legislationId])
  @@index([platformPolicyId])
  @@index([sourceType])
  @@index([parentRuleId])
  @@map("compliance_rules")
}

// ─────────────────────────────────────────────
// RESOURCE LINKS (cross-reference learning content to sources)
// ─────────────────────────────────────────────

enum ResourceTargetType {
  LEGISLATION
  PLATFORM_POLICY
  COMPLIANCE_RULE
}

model ResourceLink {
  id               String             @id @default(cuid())
  articleId        String?
  quizId           String?
  targetType       ResourceTargetType
  legislationId    String?
  platformPolicyId String?
  complianceRuleId String?
  sortOrder        Int                @default(0)
  createdAt        DateTime           @default(now())

  article        PolicyArticle?  @relation(fields: [articleId], references: [id], onDelete: Cascade)
  quiz           PolicyQuiz?     @relation(fields: [quizId], references: [id], onDelete: Cascade)
  legislation    Legislation?    @relation(fields: [legislationId], references: [id], onDelete: Cascade)
  platformPolicy PlatformPolicy? @relation(fields: [platformPolicyId], references: [id], onDelete: Cascade)
  complianceRule ComplianceRule? @relation(fields: [complianceRuleId], references: [id], onDelete: Cascade)

  @@index([articleId])
  @@index([legislationId])
  @@index([platformPolicyId])
  @@index([complianceRuleId])
  @@map("resource_links")
}
